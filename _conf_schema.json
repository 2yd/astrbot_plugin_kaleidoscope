{
  "image_size_limit_mb": {
    "description": "静态图大小限制 (MB)",
    "type": "int",
    "default": 10,
    "min": 1,
    "max": 100,
    "hint": "允许处理的普通图像最大大小"
  },
  "gif_size_limit_mb": {
    "description": "GIF大小限制 (MB)",
    "type": "int",
    "default": 15,
    "min": 1,
    "max": 200,
    "hint": "允许处理的GIF动图最大大小"
  },
  "enable_gif": {
    "description": "启用GIF处理",
    "type": "bool",
    "default": true,
    "hint": "是否启用GIF动图处理功能"
  },
  "max_gif_frames": {
    "description": "GIF最大帧数",
    "type": "int",
    "default": 200,
    "min": 10,
    "max": 500,
    "hint": "单个GIF允许处理的最大帧数"
  },
  "processing_timeout": {
    "description": "处理超时时间 (秒)",
    "type": "int",
    "default": 60,
    "min": 10,
    "max": 300,
    "hint": "图像处理最大超时（GIF建议60秒以上）"
  },
  "output_quality": {
    "description": "输出图像质量",
    "type": "int",
    "default": 85,
    "min": 1,
    "max": 100,
    "hint": "输出图像质量 (1-100)"
  },
  "silent_mode": {
    "description": "静默模式",
    "type": "bool",
    "default": false,
    "hint": "不发送处理提示消息"
  },
  "enable_auto_cleanup": {
    "description": "启用自动清理",
    "type": "bool",
    "default": true,
    "hint": "发送成功后自动删除生成的文件"
  },
  "keep_files_hours": {
    "description": "文件保留时间 (小时)",
    "type": "int",
    "default": 1,
    "min": 0,
    "max": 168,
    "hint": "生成的文件保留多久后删除 (0=立即)"
  },
  "rate_limit_per_minute": {
    "description": "频率限制 (次/分钟)",
    "type": "int",
    "default": 10,
    "min": 0,
    "max": 60,
    "hint": "每用户每分钟最多请求次数。0表示不限制。"
  },
  "max_concurrent_tasks": {
    "description": "并发处理上限",
    "type": "int",
    "default": 3,
    "min": 1,
    "max": 10,
    "hint": "同时处理图像任务的最大数量"
  }
}
